{
  "openapi": "3.0.3",
  "info": {
    "title": "MikConnect API",
    "version": "1.0.0",
    "description": "API de gestion de hotspots WiFi, tickets, revendeurs et paiements pour MikConnect.",
    "contact": { "name": "MikConnect Support", "email": "support@mikconnect.com" }
  },
  "servers": [{ "url": "/api", "description": "API v1" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "Error": { "type": "object", "properties": { "error": { "type": "string" } } },
      "Hotspot": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "location": { "type": "string" }, "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] }, "routerIp": { "type": "string" }, "routerApiPort": { "type": "integer" } } },
      "Plan": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "price": { "type": "number" }, "duration": { "type": "integer" }, "durationUnit": { "type": "string", "enum": ["minutes", "hours", "days"] }, "bandwidth": { "type": "integer" }, "dataLimit": { "type": "integer" } } },
      "Voucher": { "type": "object", "properties": { "id": { "type": "string" }, "code": { "type": "string" }, "price": { "type": "number" }, "status": { "type": "string", "enum": ["ACTIVE", "USED", "EXPIRED"] }, "hotspotId": { "type": "string" }, "planId": { "type": "string" }, "expiresAt": { "type": "string", "format": "date-time" } } },
      "Transaction": { "type": "object", "properties": { "id": { "type": "string" }, "reference": { "type": "string" }, "amount": { "type": "number" }, "method": { "type": "string" }, "status": { "type": "string", "enum": ["PENDING", "COMPLETED", "FAILED"] }, "phoneNumber": { "type": "string" } } },
      "Reseller": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "phone": { "type": "string" }, "email": { "type": "string" }, "commission": { "type": "number" } } },
      "Partner": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "type": { "type": "string", "enum": ["TECHNOLOGY", "ISP", "HARDWARE", "OTHER"] }, "contactName": { "type": "string" }, "contactEmail": { "type": "string" }, "commission": { "type": "number" } } },
      "User": { "type": "object", "properties": { "id": { "type": "string" }, "name": { "type": "string" }, "email": { "type": "string" }, "role": { "type": "string", "enum": ["ADMIN", "ISP", "RESELLER", "PARTNER"] }, "phone": { "type": "string" }, "country": { "type": "string" }, "active": { "type": "boolean" } } },
      "RoamingSession": { "type": "object", "properties": { "id": { "type": "string" }, "hotspotId": { "type": "string" }, "partnerHotspotId": { "type": "string" }, "userIdentifier": { "type": "string" }, "status": { "type": "string", "enum": ["ACTIVE", "COMPLETED"] }, "dataUsed": { "type": "integer" }, "duration": { "type": "integer" } } },
      "Notification": { "type": "object", "properties": { "id": { "type": "string" }, "type": { "type": "string", "enum": ["SMS", "WHATSAPP", "TELEGRAM"] }, "recipient": { "type": "string" }, "message": { "type": "string" }, "status": { "type": "string", "enum": ["SENT", "FAILED"] } } }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" }, "timestamp": { "type": "string" }, "uptime": { "type": "number" } } } } } } }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Creer un compte",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["name","email","password"], "properties": { "name": { "type": "string" }, "email": { "type": "string" }, "password": { "type": "string", "minLength": 6 }, "phone": { "type": "string" }, "country": { "type": "string" }, "companyName": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Compte cree" }, "400": { "description": "Email deja utilise" } }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Connexion",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["email","password"], "properties": { "email": { "type": "string" }, "password": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Token JWT + profil" }, "401": { "description": "Identifiants invalides" } }
      }
    },
    "/hotspots": {
      "get": {
        "tags": ["Hotspots"],
        "summary": "Lister mes hotspots",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Liste des hotspots", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Hotspot" } } } } } }
      },
      "post": {
        "tags": ["Hotspots"],
        "summary": "Creer un hotspot",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Hotspot" } } } },
        "responses": { "201": { "description": "Hotspot cree" } }
      }
    },
    "/plans": {
      "get": {
        "tags": ["Plans"],
        "summary": "Lister les offres",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Liste des offres", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Plan" } } } } } }
      },
      "post": {
        "tags": ["Plans"],
        "summary": "Creer une offre",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Plan" } } } },
        "responses": { "201": { "description": "Offre creee" } }
      }
    },
    "/vouchers": {
      "get": {
        "tags": ["Vouchers"],
        "summary": "Lister les tickets",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Liste des tickets", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Voucher" } } } } } }
      },
      "post": {
        "tags": ["Vouchers"],
        "summary": "Generer des tickets",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "planId": { "type": "string" }, "hotspotId": { "type": "string" }, "count": { "type": "integer", "default": 1 } } } } } },
        "responses": { "201": { "description": "Tickets crees" } }
      }
    },
    "/vouchers/validate": {
      "post": {
        "tags": ["Vouchers"],
        "summary": "Valider un code",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "code": { "type": "string" }, "hotspotId": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Ticket valide" }, "404": { "description": "Code invalide ou expire" } }
      }
    },
    "/transactions": {
      "get": {
        "tags": ["Transactions"],
        "summary": "Mes transactions",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Liste des transactions", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Transaction" } } } } } }
      }
    },
    "/payments/initiate": {
      "post": {
        "tags": ["Paiements"],
        "summary": "Initier un paiement mobile money",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["amount","method","phoneNumber"], "properties": { "amount": { "type": "number" }, "method": { "type": "string", "enum": ["MTN_MOMO","MOOV","WAVE","ORANGE_MONEY"] }, "phoneNumber": { "type": "string" }, "planId": { "type": "string" }, "hotspotId": { "type": "string" }, "customerName": { "type": "string" }, "customerEmail": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Paiement initie" } }
      }
    },
    "/payments/webhook/momo": {
      "post": {
        "tags": ["Paiements"],
        "summary": "Webhook mobile money (interne)",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "reference": { "type": "string" }, "status": { "type": "string", "enum": ["SUCCESS","FAILED"] } } } } } },
        "responses": { "200": { "description": "Webhook recu" } }
      }
    },
    "/payments/methods": {
      "get": { "tags": ["Paiements"], "summary": "Moyens de paiement disponibles", "responses": { "200": { "description": "Liste des methodes" } } }
    },
    "/resellers": {
      "get": {
        "tags": ["Revendeurs"],
        "summary": "Lister les revendeurs",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Liste des revendeurs", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Reseller" } } } } } }
      },
      "post": {
        "tags": ["Revendeurs"],
        "summary": "Ajouter un revendeur",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Reseller" } } } },
        "responses": { "201": { "description": "Revendeur cree" } }
      }
    },
    "/partners": {
      "get": {
        "tags": ["Partenaires"],
        "summary": "Lister les partenaires",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Liste des partenaires", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Partner" } } } } } }
      },
      "post": {
        "tags": ["Partenaires"],
        "summary": "Ajouter un partenaire",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Partner" } } } },
        "responses": { "201": { "description": "Partenaire cree" } }
      }
    },
    "/users": {
      "get": {
        "tags": ["Utilisateurs"],
        "summary": "Lister les utilisateurs (admin)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Liste des utilisateurs", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } } } }
      }
    },
    "/users/me": {
      "get": {
        "tags": ["Utilisateurs"],
        "summary": "Mon profil",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Profil utilisateur", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } } }
      },
      "put": {
        "tags": ["Utilisateurs"],
        "summary": "Mettre a jour mon profil",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" }, "phone": { "type": "string" }, "country": { "type": "string" }, "companyName": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Profil mis a jour" } }
      }
    },
    "/roaming/sessions": {
      "get": {
        "tags": ["Roaming"],
        "summary": "Sessions de roaming",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Liste des sessions" } }
      },
      "post": {
        "tags": ["Roaming"],
        "summary": "Demarrer une session roaming",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "partnerHotspotId": { "type": "string" }, "userIdentifier": { "type": "string" }, "planId": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Session demarree" } }
      }
    },
    "/mikrotik/test": {
      "post": {
        "tags": ["MikroTik"],
        "summary": "Tester la connexion a un routeur",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "host": { "type": "string" }, "port": { "type": "integer", "default": 8728 }, "username": { "type": "string" }, "password": { "type": "string" } } } } } },
        "responses": { "200": { "description": "Resultat du test" } }
      }
    },
    "/mikrotik/sync-vouchers": {
      "post": {
        "tags": ["MikroTik"],
        "summary": "Synchroniser les tickets vers le routeur",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Synchronisation effectuee" } }
      }
    },
    "/notifications/send": {
      "post": {
        "tags": ["Notifications"],
        "summary": "Envoyer une notification",
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "type": { "type": "string", "enum": ["SMS","WHATSAPP","TELEGRAM"] }, "recipient": { "type": "string" }, "message": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Notification envoyee" } }
      }
    }
  },
  "tags": [
    { "name": "Auth", "description": "Inscription et connexion" },
    { "name": "Hotspots", "description": "Gestion des points d'acces WiFi" },
    { "name": "Plans", "description": "Offres internet" },
    { "name": "Vouchers", "description": "Tickets d'acces" },
    { "name": "Transactions", "description": "Historique des transactions" },
    { "name": "Paiements", "description": "Paiements mobile money" },
    { "name": "Revendeurs", "description": "Gestion des revendeurs" },
    { "name": "Partenaires", "description": "Partenariats" },
    { "name": "Utilisateurs", "description": "Gestion des utilisateurs" },
    { "name": "Roaming", "description": "Itinerance entre hotspots partenaires" },
    { "name": "MikroTik", "description": "Integration routeurs MikroTik" },
    { "name": "Notifications", "description": "Envoi de notifications" },
    { "name": "System", "description": "Informations systeme" }
  ]
}
