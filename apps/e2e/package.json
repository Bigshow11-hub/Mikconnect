{
  "name": "@mikconnect/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:prepare": "node scripts/prepare-db.mjs",
    "pretest:e2e": "pnpm run db:prepare",
    "test:e2e": "playwright test --grep-invert @visual",
    "test:e2e:visual": "playwright test --grep @visual",
    "test:e2e:update": "playwright test --grep @visual --update-snapshots",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@mikconnect/config": "workspace:^",
    "@playwright/test": "^1.55.0",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
