# mikconnect API — variables d'environnement
# Copier en .env et remplir.

# Base de données PostgreSQL
DATABASE_URL="postgresql://mikconnect:mikconnect@localhost:5432/mikconnect?schema=public"

# JWT
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Chiffrement credentials Mikrotik (AES-256)
MIKROTIK_ENCRYPTION_KEY="32-bytes-hex-key-here"

# Connexion Mikrotik : "true" (défaut) simule un routeur reachable en dev
# (aucun routeur physique requis) ; "false" utilise node-routeros en prod.
MIKROTIK_MOCK="true"
# Délai réseau RouterOS API, borné entre 3 et 60 secondes.
MIKROTIK_API_TIMEOUT_SECONDS="10"
# Laisser true en production. false uniquement pour un certificat auto-signé
# dans un environnement de test maîtrisé.
MIKROTIK_TLS_REJECT_UNAUTHORIZED="true"

# Cinetpay
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""
CINETPAY_SECRET_KEY=""
CINETPAY_BASE_URL="https://api-checkout.cinetpay.com/v2"
# true en développement : paiement accepté et SMS simulé localement.
CINETPAY_MOCK="true"

# SMS (passerelle principale + fallback)
SMS_PROVIDER="local"
SMS_API_KEY=""
SMS_API_URL=""
SMS_SENDER="mikconnect"
SMS_FALLBACK_PROVIDER="twilio"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# FreeRADIUS (lecture accounting)
RADIUS_DB_URL="postgresql://mikconnect:mikconnect@localhost:5432/radius?schema=public"
RADIUS_SYNC_ENABLED="true"
RADIUS_SYNC_INTERVAL_MS="15000"

# Redis (jobs BullMQ)
REDIS_URL="redis://localhost:6379"

# Application
PORT=4000
NODE_ENV="development"
# Origines autorisées, séparées par des virgules en staging/production.
CORS_ORIGIN="http://localhost:3000"
PUBLIC_API_URL="http://localhost:4000"
PUBLIC_WEB_URL="http://localhost:3000"
