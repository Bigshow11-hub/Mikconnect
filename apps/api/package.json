  },
  "dependencies": {
    "@nestjs/common": "^10.4.6",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.6",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6",
    "@prisma/client": "^5.22.0",
    "@types/express": "^5.0.6",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
