{
  "appId": "com.mikconnect.flash",
  "productName": "MikConnect Flash",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main.js",
    "preload.js",
    "renderer/**/*",
    "build.config.json"
  ],
  "win": {
    "target": ["nsis"],
    "icon": "assets/icon.ico",
    "publisherName": "MikConnect"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "shortcutName": "MikConnect Flash"
  },
  "extraMetadata": {
    "main": "main.js"
  }
}
